# Learn Accounting Agent 环境配置示例
# 复制此文件为 .env 并填入实际配置值

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2000

# 数据库配置
DATABASE_URL=sqlite:///accounting_agent.db
DATABASE_ECHO=false

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false

# 调试配置
DEBUG=false
LOG_LEVEL=INFO

# 文件路径配置
DATA_DIR=data
REPORTS_DIR=reports
TEMP_DIR=temp
RULES_FILE=config/rules.json
REPORT_TEMPLATE_DIR=templates

# 审核配置
MAX_BATCH_SIZE=1000
ANOMALY_THRESHOLD=2.0
OUTLIER_METHOD=zscore
MIN_SAMPLES_FOR_ANOMALY=10

# 报告配置
DEFAULT_REPORT_FORMAT=html
INCLUDE_CHARTS=true
